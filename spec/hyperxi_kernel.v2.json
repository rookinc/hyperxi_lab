        "status": "verified_computationally"
      }
    ]
  },
  "transport_group": {
    "acting_space": "flag_space",
    "discovered_subgroup": {
      "size": 120,
      "center_size": 2,
      "central_involution_cycle_type": {
        "2": 60
      }
    },
    "interpretation_notes": [
